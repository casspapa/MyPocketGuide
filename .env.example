# =============================================================================
# My Pocket Guide — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# ── Gemini Live Model ─────────────────────────────────────────────────────────
AGENT_MODEL=gemini-live-2.5-flash-native-audio

# ── Vertex AI RAG ─────────────────────────────────────────────────────────────
RAG_LOCATION=us-west1
RAG_CORPUS=projects/YOUR_PROJECT/locations/us-west1/ragCorpora/YOUR_CORPUS_ID

# ── Cloud SQL (PostgreSQL) ────────────────────────────────────────────────────
CLOUDSQL_INSTANCE=your-project:us-central1:museum-db
DB_USER=museum_user
DB_PASS=your-database-password
DB_NAME=museum_sessions

# ── reCAPTCHA v3 (optional bot protection) ───────────────────────────────────
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
